{
    "name": "roadynet/skillbuilder-showcase",
    "description": "Public portfolio evidence for the private SkillBuilder Symfony learning platform.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "lint:php": "python tests/php_lint.py",
        "analyse": "phpstan analyse --configuration=phpstan.neon --no-progress",
        "test": "phpunit",
        "audit:showcase": "python tests/showcase_audit.py",
        "smoke:public": "python tests/public_smoke.py",
        "verify": [
            "@lint:php",
            "@analyse",
            "@test",
            "@audit:showcase"
        ]
    }
}
