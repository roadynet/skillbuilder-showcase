{
    "name": "roadynet/skillbuilder-showcase",
    "description": "Public PHP examples for the SkillBuilder learning platform showcase.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "check:composer": "composer validate --strict",
        "test": "phpunit --colors=always",
        "stan": "phpstan analyse --memory-limit=512M",
        "qa": [
            "@check:composer",
            "@test",
            "@stan"
        ]
    }
}
